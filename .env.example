PORT=5000
NODE_ENV=development

# Database (Supabase PostgreSQL connection string)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT
JWT_SECRET=lexaid_jwt_secret_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# bcrypt rounds
BCRYPT_ROUNDS=12

# SMS Gateway — Text.lk (Bearer token auth)
SMS_ENABLED=true
SMS_API_TOKEN=your_textlk_bearer_token   # format: "id|token" from Text.lk dashboard
SMS_SENDER_ID=LexAid                     # must be pre-approved by Text.lk

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# AES-256 encryption key for PII (must be 32 chars)
ENCRYPTION_KEY=lexaid_enc_key_32chars_changeme!!

# File upload
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads

# OpenAI API (§4.8 AI-assisted features)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
# Model — gpt-4o-mini is fast and cost-effective for classification/simplification
OPENAI_MODEL=gpt-4o-mini

# Supabase Storage (§4.8 - for ID card and selfie uploads)
# These are required for lawyer verification. If missing, fallbacks to local /uploads/
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=lawyer-verifications
